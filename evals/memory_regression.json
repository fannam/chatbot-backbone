          "expected_prompt_substrings": [
            "user: Call me Alice."
          ]
        }
      ],
      "expected_answer_substrings": [
        "Alice"
      ],
      "expect_summary_present": false,
      "expected_active_memory_count": 0
    }
  ]
}
