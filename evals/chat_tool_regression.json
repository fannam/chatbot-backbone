    {
      "id": "rejected-tool-allowlist",
      "message": "Can you check the live weather in San Francisco?",
      "script": [
        {
          "type": "tool_call_batch",
          "response_id": "resp-7",
          "usage": {
            "input_tokens": 28,
            "output_tokens": 7,
            "total_tokens": 35
          },
          "tool_calls": [
            {
              "call_id": "tool-4",
              "name": "weather_lookup",
              "arguments": {
                "city": "San Francisco"
              }
            }
          ]
        },
        {
          "type": "final_answer",
          "response_id": "resp-8",
          "content": "I cannot check live weather because that tool is not allowlisted in this backend.",
          "usage": {
            "input_tokens": 14,
            "output_tokens": 7,
            "total_tokens": 21
          }
        }
      ],
      "expected_tool_runs": [
        {
          "tool_name": "weather_lookup",
          "status": "rejected",
          "input_subset": {
            "city": "San Francisco"
          }
        }
      ],
      "expected_answer_substrings": [
        "not allowlisted"
      ],
      "notes": "Confirms rejected tool calls are surfaced in metadata and final answer can handle the failure path."
    },
    {
