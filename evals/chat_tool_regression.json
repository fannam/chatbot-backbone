    {
      "id": "kb-billing-disambiguation",
      "message": "Which document explains refunds instead of incident response?",
      "history": [
        {
          "role": "user",
          "content": "We were comparing support docs."
        },
        {
          "role": "assistant",
          "content": "Okay, I will distinguish billing answers from incident guidance."
        }
      ],
      "script": [
        {
          "type": "tool_call_batch",
          "response_id": "resp-3",
          "usage": {
            "input_tokens": 42,
            "output_tokens": 10,
            "total_tokens": 52
          },
          "tool_calls": [
            {
              "call_id": "tool-2",
              "name": "search_knowledge_base",
              "arguments": {
                "query": "Which document explains refunds instead of incident response?",
                "top_k": 2
              }
            }
          ]
        },
        {
          "type": "final_answer",
          "response_id": "resp-4",
          "content": "The billing FAQ explains refunds; the incident runbook is for response workflow, not refunds.",
          "usage": {
            "input_tokens": 22,
            "output_tokens": 12,
            "total_tokens": 34
          }
        }
      ],
      "expected_tool_runs": [
        {
          "tool_name": "search_knowledge_base",
          "status": "completed",
          "input_subset": {
            "query": "Which document explains refunds instead of incident response?",
            "top_k": 2
          },
          "output_subset": {
            "hits": [
              {
                "filename": "billing_faq.md"
              }
            ]
          }
        }
      ],
      "expected_sources": [
        {
          "filename": "billing_faq.md"
        }
      ],
      "minimum_expected_source_hits": 1,
      "expected_answer_substrings": [
        "billing FAQ",
        "refunds"
      ],
      "forbidden_answer_substrings": [
        "incident commander"
      ],
      "notes": "Uses seeded history and verifies disambiguation between billing and ops docs."
    },
    {
