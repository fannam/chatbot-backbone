          "response_id": "resp-5",
          "usage": {
            "input_tokens": 25,
            "output_tokens": 8,
            "total_tokens": 33
          },
          "tool_calls": [
            {
              "call_id": "tool-3",
              "name": "calculator",
              "arguments": {
                "expression": "(2 + 3) * 4"
              }
            }
          ]
        },
        {
          "type": "final_answer",
          "response_id": "resp-6",
          "content": "The result is 20.",
