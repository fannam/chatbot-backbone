APP_NAME=chatbot-api
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODEL_INPUT_PRICE_PER_1M_TOKENS=0.40
OPENAI_MODEL_OUTPUT_PRICE_PER_1M_TOKENS=1.60
LLM_TIMEOUT_SECONDS=30
DOCUMENT_MAX_BYTES=5242880
REQUEST_MAX_BODY_BYTES=10485760
DOCUMENT_CHUNK_SIZE_CHARS=1200
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_EMBEDDING_DIMENSIONS=1536
DOCUMENT_EMBEDDING_BATCH_SIZE=32
DOCUMENT_EMBEDDING_TASK_MAX_RETRIES=3
DOCUMENT_EMBEDDING_TASK_RETRY_BACKOFF_SECONDS=30
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=1
RETRIEVAL_CANDIDATE_LIMIT=12
RETRIEVAL_RERANK_ENABLED=false
TOOL_MAX_ROUNDS=4
TOOL_EXECUTION_TIMEOUT_SECONDS=15
TOOL_SEARCH_TOP_K=3
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
MODERATION_ENABLED=false
MODERATION_MODEL=omni-moderation-latest
JAILBREAK_DETECTION_ENABLED=false
PII_DETECTION_ENABLED=false
OUTPUT_GUARDRAILS_ENABLED=false
MEMORY_ENABLED=true
MEMORY_RECENT_MESSAGE_WINDOW=6
MEMORY_SUMMARY_TRIGGER_MESSAGES=12
MEMORY_MAX_SUMMARY_CHARS=2000
MEMORY_MAX_ACTIVE_ITEMS=8
MEMORY_LONG_TERM_ENABLED=true
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_INCLUDE_REQUEST_METADATA=false
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=chatbot-api
LANGSMITH_ENDPOINT=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@postgres:5432/chatbot
LANGGRAPH_CHECKPOINT_DATABASE_URL=postgresql://chatbot:chatbot@postgres:5432/chatbot

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
